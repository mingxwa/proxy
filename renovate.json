{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "enabledManagers": [
    "github-actions",
    "pre-commit",
    "pip_requirements",
    "bazel-module",
    "bazelisk"
  ],
  "pre-commit": {
    "enabled": true
  },
  "separateMajorMinor": false,
  "updateLockFiles": false,
  "prHourlyLimit": 0,
  "packageRules": [
    {
      "description": "Collect every bump into a single weekly PR.",
      "matchManagers": [
        "github-actions",
        "pre-commit",
        "pip_requirements",
        "bazel-module",
        "bazelisk"
      ],
      "groupName": "dependencies"
    }
  ],
  "postUpgradeTasks": {
    "description": "Refresh MODULE.bazel.lock to track the bazel_dep versions Renovate bumped.",
    "commands": ["bazel mod graph --lockfile_mode=update"],
    "fileFilters": ["MODULE.bazel.lock"],
    "executionMode": "branch"
  }
}
